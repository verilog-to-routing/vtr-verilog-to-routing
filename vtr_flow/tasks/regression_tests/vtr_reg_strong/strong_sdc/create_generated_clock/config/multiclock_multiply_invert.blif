# Two-clock circuit where clk2 is constrained via SDC as an inverted generated
# clock using multiply_by 3 on an external port clock. The -invert flag shifts
# the generated clock's rising edge by half its period (1.0 ns), offsetting it
# from the source rising edge and allowing setup time to be met.

.model multiclock_multiply_invert
.inputs in1 in2 in3 clk clk2
.outputs out1 out2 out3

.latch to_FFA FFA re clk 0
.latch to_FFC FFC re clk 0
.latch to_FFD FFD re clk2 0
.latch to_FFB FFB re clk2 0

.names FFA FFB to_FFC
11 1
.names FFA FFB to_FFD
11 1

.names in1 to_FFA
1 1

.names in2 to_FFB
1 1

.names FFC out1
1 1

.names FFD out2
1 1

.names in3 out3
1 1

.end
