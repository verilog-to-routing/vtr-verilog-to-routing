# Same circuit structure as clock_divider.blif; used to test that a generated
# clock (divide_by 2) can be derived from a source clock whose rising edge does
# not start at 0 ns (i.e., created with -waveform {X Y} where X > 0).

.model clock_divider_nonzero_rise
.inputs in1 in2 in3 clk
.outputs out1 out2 out3

.latch div_clk_inv div_clk re clk 0

.names div_clk div_clk_inv
0 1

.latch to_FFA FFA re clk 0
.latch to_FFC FFC re clk 0
.latch to_FFD FFD re div_clk 0
.latch to_FFB FFB re div_clk 0

.names FFA FFB to_FFC
11 1
.names FFA FFB to_FFD
11 1

.names in1 to_FFA
1 1

.names in2 to_FFB
1 1

.names FFC out1
1 1

.names FFD out2
1 1

.names in3 out3
1 1

.end
