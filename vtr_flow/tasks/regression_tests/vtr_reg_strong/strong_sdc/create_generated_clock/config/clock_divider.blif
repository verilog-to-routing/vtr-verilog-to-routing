# Canonical single-clock circuit with an internal clock divider.
# clk drives flip-flops directly; div_clk (the Q output of a latch clocked by
# clk) is a divided-by-2 clock used by a second set of flip-flops.
#
# This file is the shared circuit for all tests that need this topology.
# Several other .blif files in this directory are symlinks to this file —
# each paired with a different .sdc file to test a distinct SDC constraint.
# The .model name below does not need to match the symlink name; VPR uses
# the port and pin names (clk, div_clk) for constraint matching, not the
# model name.

.model clock_divider
.inputs in1 in2 in3 clk
.outputs out1 out2 out3

# Create a clock divider which will cause div_inst to have a period
# of half of clk.
.latch div_clk_inv div_clk re clk 0

# Inverted version of div_clk used for the clock divider.
.names div_clk div_clk_inv
0 1

.latch to_FFA FFA re clk 0
.latch to_FFC FFC re clk 0
.latch to_FFD FFD re div_clk 0
.latch to_FFB FFB re div_clk 0

.names FFA FFB to_FFC
11 1
.names FFA FFB to_FFD
11 1

.names in1 to_FFA
1 1

.names in2 to_FFB
1 1

.names FFC out1
1 1

.names FFD out2
1 1

.names in3 out3
1 1

.end