<!--
Basic test placement constraint file. Constrains half of the blocks to one side
of the chip and the other half to the other side. This is just simply to test
that AP is able to adhere to large placement constraint regions.

This also constrains the block to particular logical block types. This should
not be an issue for AP.
-->
<vpr_constraints tool_name="vpr">
<partition_list>
    <partition name="clbA_part">
        <add_atom name_pattern="\[.*\]" is_regex="true"/>
        <add_region x_low="1" y_low="1" x_high="22" y_high="44"/>
        <add_logical_block name_pattern="clbA"/>
    </partition>
    <partition name="clbB_part">
        <add_atom name_pattern="n_n[0-9]+" is_regex="true"/>
        <add_region x_low="23" y_low="1" x_high="44" y_high="44"/>
        <add_logical_block name_pattern="clbB"/>
    </partition>
</partition_list>
</vpr_constraints>
